<!-- ====== Contact Start ====== -->
<section id="contact" class="relative py-20 md:py-[120px]">
  <div class="absolute top-0 left-0 -z-[1] w-full dark:bg-dark h-full"></div>
  <div class="absolute top-0 left-0 -z-[1] h-1/2 w-full bg-[#E9F9FF] dark:bg-dark-700 lg:h-[45%] xl:h-1/2"></div>
  <div class="container px-4">
    <div class="mx-auto max-w-[1200px]">
      <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] items-start">
        <div class="rounded-[30px] bg-[#F8FBFF] dark:bg-[#0F172A] p-8 sm:p-10 lg:p-12 shadow-[0_32px_80px_rgba(1,28,80,0.08)] dark:shadow-none">
          <span class="inline-block rounded-full border border-primary/20 bg-primary/5 px-4 py-1 text-sm font-semibold text-primary">
            CONTACT US
          </span>
          <h2 class="mt-6 text-4xl font-semibold leading-tight text-dark dark:text-white sm:text-[42px]">
            Have a question? Send us a message.
          </h2>
          <p class="mt-5 max-w-3xl text-base leading-relaxed text-body-color dark:text-dark-6">
            Whether you need a home inspection, a quote, or help booking service across Southwest Florida, our team is ready to help.
          </p>

          <div class="mt-10 grid gap-6 sm:grid-cols-2">
            <article class="rounded-[24px] border border-[#E8F0FF] bg-white p-6 shadow-sm dark:border-[#1F2937] dark:bg-dark-2">
              <div class="flex items-center gap-4">
                <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6">
                    <path d="M4 4H20V20H4V4Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M4 7L12 13L20 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <div>
                  <h5 class="text-lg font-semibold text-dark dark:text-white">How Can We Help?</h5>
                  <p class="mt-1 text-sm text-body-color dark:text-dark-6">Ready to answer questions, requests, and booking details.</p>
                </div>
              </div>
              <div class="mt-6 space-y-4 text-sm text-body-color dark:text-dark-6">
                <div>
                  <p class="text-xs uppercase tracking-[0.16em] text-gray-500 dark:text-dark-5">Email</p>
                  <a href="mailto:info@abovebeyondhomesolutions.com" class="mt-2 inline-block text-base font-semibold text-dark dark:text-white hover:text-primary">
                    info@abovebeyondhomesolutions.com
                  </a>
                </div>
                <div>
                  <p class="text-xs uppercase tracking-[0.16em] text-gray-500 dark:text-dark-5">Phone</p>
                  <a href="tel:+12394163505" class="mt-2 inline-block text-base font-semibold text-dark dark:text-white hover:text-primary">
                    (239) 416-3505
                  </a>
                </div>
                <div>
                  <p class="text-xs uppercase tracking-[0.16em] text-gray-500 dark:text-dark-5">Address</p>
                  <p class="mt-2 text-base font-semibold text-dark dark:text-white leading-relaxed">
                    1002 W 9th Street<br />Lehigh Acres, FL 33972
                  </p>
                </div>
              </div>
            </article>

            <article class="rounded-[24px] border border-[#E8F0FF] bg-white p-6 shadow-sm dark:border-[#1F2937] dark:bg-dark-2">
              <div class="flex items-center gap-4">
                <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6">
                    <path d="M12 2C8.134 2 5 5.134 5 9C5 14.25 12 22 12 22C12 22 19 14.25 19 9C19 5.134 15.866 2 12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M12 11.5C13.3807 11.5 14.5 10.3807 14.5 9C14.5 7.61929 13.3807 6.5 12 6.5C10.6193 6.5 9.5 7.61929 9.5 9C9.5 10.3807 10.6193 11.5 12 11.5Z" fill="currentColor"/>
                  </svg>
                </span>
                <div>
                  <h5 class="text-lg font-semibold text-dark dark:text-white">Areas We Serve</h5>
                  <p class="mt-1 text-sm text-body-color dark:text-dark-6">Serving Southwest Florida with reliable home inspection coverage.</p>
                </div>
              </div>
              <ul class="mt-6 grid gap-2 text-sm text-body-color dark:text-dark-6 sm:grid-cols-2">
                <li>Lehigh Acres</li>
                <li>Fort Myers</li>
                <li>Naples</li>
                <li>Cape Coral</li>
                <li>North Port</li>
                <li>Port Charlotte</li>
                <li>LaBelle</li>
                <li>Sanibel Island</li>
                <li>Estero</li>
                <li>Alva</li>
                <li>Punta Gorda</li>
                <li>Marco Island</li>
              </ul>
            </article>
          </div>
        </div>

        <div class="wow fadeInUp rounded-[30px] bg-white dark:bg-dark-2 p-8 sm:p-10 shadow-testimonial dark:shadow-none" data-wow-delay=".2s">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
            Message Us
          </span>
          <h3 class="mt-6 text-2xl font-semibold text-dark dark:text-white">Send us a Message</h3>
          <p class="mt-4 text-base leading-relaxed text-body-color dark:text-dark-6">
            Share your question or inspection details and we’ll get back to you quickly.
          </p>

          <form method="POST" action="https://formspree.io/f/xpznnqgk" class="mt-10 space-y-6">
            <div>
              <label for="fullName" class="block text-sm font-medium text-body-color dark:text-dark-6 mb-3">Full Name*</label>
              <input type="text" id="fullName" name="fullName" placeholder="Adam Gelius" required
                class="w-full rounded-[16px] border border-[#E8EEF5] bg-transparent px-4 py-3 text-body-color dark:text-dark-6 placeholder:text-body-color/60 outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/10" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-body-color dark:text-dark-6 mb-3">Email*</label>
              <input type="email" id="email" name="email" placeholder="example@yourmail.com" required
                class="w-full rounded-[16px] border border-[#E8EEF5] bg-transparent px-4 py-3 text-body-color dark:text-dark-6 placeholder:text-body-color/60 outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/10" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-body-color dark:text-dark-6 mb-3">Phone*</label>
              <input type="text" id="phone" name="phone" placeholder="+885 1254 5211 552" required
                class="w-full rounded-[16px] border border-[#E8EEF5] bg-transparent px-4 py-3 text-body-color dark:text-dark-6 placeholder:text-body-color/60 outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/10" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-body-color dark:text-dark-6 mb-3">Message*</label>
              <textarea id="message" name="message" rows="5" placeholder="type your message here" required
                class="w-full rounded-[16px] border border-[#E8EEF5] bg-transparent px-4 py-3 text-body-color dark:text-dark-6 placeholder:text-body-color/60 outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/10 resize-none"></textarea>
            </div>
            <button type="submit"
              class="inline-flex w-full items-center justify-center rounded-[16px] bg-primary py-3 px-10 text-base font-medium text-white transition duration-300 ease-in-out hover:bg-blue-dark">
              Send
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- ====== Contact End ====== -->