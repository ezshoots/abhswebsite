---
const features = [
  {
    icon: 'assets/features/icon-01.svg',
    title: 'General Home Inspection (Existing & New Construction)',
    slug: 'general-home-inspection',
    ref: '/generalhomeinspection',
    refTitle: 'Learn more',
    description:
      'Whether you’re buying or selling, our detailed inspections uncover hidden defects and give you the confidence to move forward with peace of mind.',
  },
  {
    icon: 'assets/features/icon-02.svg',
    title: '4 Point / Wind Mitigation Inspections',
    slug: '4-point-wind-mitigation',
    ref: '/4pointandwind',
    refTitle: 'Learn more',
    description:
      "Essential for insurance coverage, our 4-Point and Wind Mitigation inspections evaluate your home’s key systems and storm-resistant features, helping you save on premiums and stay protected.",
  },
  {
    icon: 'assets/features/icon-03.svg',
    title: 'Lateral Sewer Scope Inspections',
    slug: 'lateral-sewer-scope',
    ref: '/services/lateral-sewer-scope',
    refTitle: 'Learn more',
    description:
      'Our lateral sewer scope inspection uses a high-resolution camera to evaluate the main sewer line, identifying concerns like blockages, root intrusion, and pipe damage. This includes newer homes where installation issues or debris are common.',
  },
  {
    icon: 'assets/features/icon-04.svg',
    title: 'Water / Air Quality Sampling',
    slug: 'water-air-quality',
    ref: '/services/water-air-quality',
    refTitle: 'Learn more',
    description:
      'We offer friendly, thorough water & air testing services in Florida, checking for contaminants like bacteria, lead, and other substances that may affect your family’s well-being.',
  },
  {
    icon: 'assets/features/icon-04.svg',
    title: 'Home Watch Services',
    slug: 'home-watch',
    ref: '/services/home-watch',
    refTitle: 'Learn more',
    description:
      "Routine scheduled property checks while you’re away, looking for water damage, mold, HVAC issues, pests, and security concerns. Every visit is documented with photos and reports.",
  },
];
---

<!-- ====== Features Section Start -->
<section class="relative py-20 lg:py-[120px] dark:bg-dark">
  <!-- subtle background treatment -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute -top-24 left-1/2 h-72 w-[38rem] -translate-x-1/2 rounded-full bg-primary/10 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-56 w-56 rounded-full bg-primary/5 blur-2xl"></div>
  </div>

  <div class="container relative">
    <div class="mx-auto mb-12 max-w-2xl text-center lg:mb-[70px]">
      <span class="mb-3 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
        Home Inspection Services
      </span>

      <h2 class="mt-3 text-3xl font-bold tracking-tight text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
        Making an Impact Through Honest, Reliable, and Professional Home Inspections
      </h2>

      <p class="mt-4 text-base leading-relaxed text-body-color dark:text-dark-6">
        At Above and Beyond Home Solutions, we deliver thorough, trustworthy inspections that empower homeowners and buyers to make informed decisions. With advanced tools and a commitment to excellence, we help shape safer homes, one inspection at a time.
      </p>

      <!-- Animated house illustration -->
      <div id="hero-house" class="mx-auto mt-8 max-w-[200px] sm:max-w-[240px]">
        <svg viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" aria-hidden="true">
          <g class="house-foundation">
            <rect x="18" y="162" width="204" height="22" rx="3"
              stroke="rgba(55,88,249,0.4)" stroke-width="1.5" fill="rgba(55,88,249,0.04)"/>
            <line x1="66" y1="162" x2="66" y2="184" stroke="rgba(55,88,249,0.15)" stroke-width="1"/>
            <line x1="120" y1="162" x2="120" y2="184" stroke="rgba(55,88,249,0.15)" stroke-width="1"/>
            <line x1="174" y1="162" x2="174" y2="184" stroke="rgba(55,88,249,0.15)" stroke-width="1"/>
          </g>
          <g class="house-walls">
            <rect x="30" y="90" width="180" height="74" stroke="rgba(55,88,249,0.5)" stroke-width="1.5" fill="rgba(55,88,249,0.04)"/>
            <rect x="99" y="122" width="42" height="42" rx="2"
              stroke="rgba(55,88,249,0.35)" stroke-width="1.2" fill="rgba(55,88,249,0.1)"/>
            <circle cx="135" cy="144" r="2.5" fill="rgba(55,88,249,0.5)"/>
            <rect x="44" y="104" width="38" height="28" rx="2"
              stroke="rgba(55,88,249,0.35)" stroke-width="1.2" fill="rgba(55,88,249,0.07)"/>
            <line x1="63" y1="104" x2="63" y2="132" stroke="rgba(55,88,249,0.2)" stroke-width="0.8"/>
            <line x1="44" y1="118" x2="82" y2="118" stroke="rgba(55,88,249,0.2)" stroke-width="0.8"/>
            <rect x="158" y="104" width="38" height="28" rx="2"
              stroke="rgba(55,88,249,0.35)" stroke-width="1.2" fill="rgba(55,88,249,0.07)"/>
            <line x1="177" y1="104" x2="177" y2="132" stroke="rgba(55,88,249,0.2)" stroke-width="0.8"/>
            <line x1="158" y1="118" x2="196" y2="118" stroke="rgba(55,88,249,0.2)" stroke-width="0.8"/>
          </g>
          <g class="house-roof">
            <polygon points="18,91 120,22 222,91"
              stroke="rgba(55,88,249,0.65)" stroke-width="1.5" fill="rgba(55,88,249,0.06)" stroke-linejoin="round"/>
            <rect x="158" y="42" width="16" height="28"
              stroke="rgba(55,88,249,0.35)" stroke-width="1.2" fill="rgba(55,88,249,0.04)"/>
            <line x1="18" y1="91" x2="222" y2="91" stroke="rgba(55,88,249,0.15)" stroke-width="0.8"/>
          </g>
        </svg>
      </div>
    </div>

<div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:gap-8">
  {
    features.map((feature) => (
      <article>
        <div class="group h-full rounded-2xl border border-black/5 bg-white/70 p-6 shadow-sm backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:ring-1 hover:ring-primary/20 dark:border-white/10 dark:bg-dark/40">
          <div class="mb-5 inline-flex items-center gap-4">
            <div class="relative grid h-12 w-12 place-items-center rounded-2xl bg-primary/10 ring-1 ring-primary/20 transition-transform duration-300 group-hover:scale-[1.03]">
              <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary/20 to-transparent opacity-70"></div>
              <img
                src={feature.icon}
                alt={`${feature.title} icon`}
                class="relative h-6 w-6"
                loading="lazy"
                decoding="async"
              />
            </div>

            <h3 class="text-lg font-semibold leading-snug text-dark dark:text-white">
              {feature.title}
            </h3>
          </div>

          <p class="mb-6 text-sm leading-relaxed text-body-color dark:text-dark-6">
            {feature.description}
          </p>

          <a
            href={feature.ref}
            aria-label={`Learn more about ${feature.title}`}
            class="inline-flex items-center gap-2 text-sm font-semibold text-dark transition-colors hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 dark:text-white"
          >
            {feature.refTitle}
            <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
              →
            </span>
          </a>
        </div>
      </article>
    ))
  }
</div>
    </div>
  </div>
</section>

<style>
  .house-foundation,
  .house-walls,
  .house-roof {
    opacity: 0;
  }
  .house-foundation {
    transform: translateY(18px);
    transition: opacity 0.6s ease 0.1s, transform 0.6s ease 0.1s;
  }
  .house-walls {
    transform: translateY(12px);
    transition: opacity 0.6s ease 0.32s, transform 0.6s ease 0.32s;
  }
  .house-roof {
    transform: translateY(-18px);
    transition: opacity 0.6s ease 0.54s, transform 0.6s ease 0.54s;
  }
  #hero-house.assembled .house-foundation,
  #hero-house.assembled .house-walls,
  #hero-house.assembled .house-roof {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const house = document.getElementById('hero-house');
  if (house) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          setTimeout(() => house.classList.add('assembled'), 300);
          observer.disconnect();
        }
      },
      { threshold: 0.15 }
    );
    observer.observe(house);
  }
</script>
<!-- ====== Features Section End -->