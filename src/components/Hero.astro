<style>
  .house-foundation,
  .house-walls,
  .house-roof {
    opacity: 0;
  }
  .house-foundation {
    transform: translateY(18px);
    transition: opacity 0.6s ease 0.1s, transform 0.6s ease 0.1s;
  }
  .house-walls {
    transform: translateY(12px);
    transition: opacity 0.6s ease 0.32s, transform 0.6s ease 0.32s;
  }
  .house-roof {
    transform: translateY(-18px);
    transition: opacity 0.6s ease 0.54s, transform 0.6s ease 0.54s;
  }
  #hero-house.assembled .house-foundation,
  #hero-house.assembled .house-walls,
  #hero-house.assembled .house-roof {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const house = document.getElementById('hero-house');
  if (house) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          setTimeout(() => house.classList.add('assembled'), 300);
          observer.disconnect();
        }
      },
      { threshold: 0.15 }
    );
    observer.observe(house);
  }
</script>
