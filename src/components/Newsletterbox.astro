<div
  class="wow fadeInUp relative mb-12 overflow-hidden rounded-xl"
  data-wow-delay=".1s"
>
  <!-- House illustration with gradient overlay -->
  <div class="relative h-44 w-full overflow-hidden rounded-t-xl bg-slate-900">
    <!-- Night sky gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-slate-800 via-slate-900 to-slate-950"></div>

    <!-- Stars -->
    <div class="absolute inset-0 overflow-hidden">
      <span class="absolute top-3 left-8 h-[2px] w-[2px] rounded-full bg-white/70"></span>
      <span class="absolute top-6 left-20 h-[2px] w-[2px] rounded-full bg-white/50"></span>
      <span class="absolute top-4 left-32 h-[3px] w-[3px] rounded-full bg-white/80"></span>
      <span class="absolute top-8 right-10 h-[2px] w-[2px] rounded-full bg-white/60"></span>
      <span class="absolute top-3 right-24 h-[2px] w-[2px] rounded-full bg-white/70"></span>
      <span class="absolute top-10 right-40 h-[2px] w-[2px] rounded-full bg-white/50"></span>
      <span class="absolute top-2 left-1/2 h-[2px] w-[2px] rounded-full bg-white/60"></span>
    </div>

    <!-- Moon -->
    <div class="absolute top-4 right-8 h-8 w-8 rounded-full bg-amber-100/90 shadow-[0_0_20px_6px_rgba(251,191,36,0.3)]"></div>

    <!-- House SVG -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2">
      <svg width="180" height="130" viewBox="0 0 180 130" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- House body -->
        <rect x="30" y="65" width="120" height="65" fill="#1e293b" stroke="#334155" stroke-width="1.5"/>
        <!-- Roof -->
        <polygon points="20,67 90,15 160,67" fill="#0f172a" stroke="#334155" stroke-width="1.5"/>
        <!-- Chimney -->
        <rect x="118" y="28" width="14" height="26" fill="#0f172a" stroke="#334155" stroke-width="1"/>
        <!-- Door -->
        <rect x="73" y="95" width="24" height="35" rx="2" fill="#0ea5e9" fill-opacity="0.3" stroke="#0ea5e9" stroke-width="1"/>
        <!-- Door knob -->
        <circle cx="92" cy="114" r="2" fill="#0ea5e9"/>
        <!-- Left window (lit up) -->
        <rect x="40" y="78" width="26" height="22" rx="2" fill="#fbbf24" fill-opacity="0.25" stroke="#fbbf24" stroke-width="1"/>
        <line x1="53" y1="78" x2="53" y2="100" stroke="#fbbf24" stroke-opacity="0.5" stroke-width="0.8"/>
        <line x1="40" y1="89" x2="66" y2="89" stroke="#fbbf24" stroke-opacity="0.5" stroke-width="0.8"/>
        <!-- Right window (lit up) -->
        <rect x="114" y="78" width="26" height="22" rx="2" fill="#fbbf24" fill-opacity="0.25" stroke="#fbbf24" stroke-width="1"/>
        <line x1="127" y1="78" x2="127" y2="100" stroke="#fbbf24" stroke-opacity="0.5" stroke-width="0.8"/>
        <line x1="114" y1="89" x2="140" y2="89" stroke="#fbbf24" stroke-opacity="0.5" stroke-width="0.8"/>
        <!-- Ground -->
        <rect x="0" y="128" width="180" height="4" fill="#0f172a"/>
        <!-- Path to door -->
        <rect x="81" y="120" width="8" height="10" fill="#1e3a5f" fill-opacity="0.6"/>
        <!-- Window glow -->
        <ellipse cx="53" cy="100" rx="13" ry="4" fill="#fbbf24" fill-opacity="0.08"/>
        <ellipse cx="127" cy="100" rx="13" ry="4" fill="#fbbf24" fill-opacity="0.08"/>
      </svg>
    </div>

    <!-- Subtle ground glow -->
    <div class="absolute bottom-0 left-1/2 h-6 w-40 -translate-x-1/2 rounded-full bg-blue-500/10 blur-xl"></div>
  </div>

  <!-- CTA content -->
  <div class="rounded-b-xl border border-t-0 border-stroke bg-white px-6 py-6 text-center dark:border-dark-3 dark:bg-dark-2">
    <h3 class="mb-2 text-lg font-bold text-dark dark:text-white">
      Ready to Schedule?
    </h3>
    <p class="mb-5 text-sm leading-relaxed text-body-color dark:text-dark-6">
      InterNACHI-certified inspections for buyers, sellers, and homeowners across Southwest Florida.
    </p>
    <a
      href="/schedule"
      class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-blue-600 py-3 px-5 text-sm font-semibold text-white shadow-sm transition-all duration-300 hover:-translate-y-[1px] hover:bg-[#2563EB] hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300/60"
    >
      Schedule Home Inspection
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
    <p class="mt-3 text-xs text-body-color dark:text-dark-6">
      (239) 416-3505 &nbsp;·&nbsp; Lehigh Acres, FL
    </p>
  </div>
</div>
