---
const bundles = [
  {
    popular: false,
    name: 'Essential Package',
    startingAt: '450',
    description: 'The foundation for any real estate transaction covers all major insurance and disclosure requirements.',
    includes: [
      { label: 'General Home Inspection', inherited: false },
      { label: '4-Point Inspection Form', inherited: false },
      { label: 'Wind Mitigation OIR-B1-1802 Form', inherited: false },
    ],
  },
  {
    popular: false,
    name: 'Premium Package',
    startingAt: '750',
    description: 'Everything in Essential, plus a deeper look at your sewer line and thermal imaging to find hidden issues.',
    includes: [
      { label: 'General Home Inspection', inherited: true },
      { label: '4-Point Inspection Form', inherited: true },
      { label: 'Wind Mitigation OIR-B1-1802 Form', inherited: true },
      { label: 'Lateral Sewer Scope Inspection', inherited: false },
      { label: 'Thermal Scope Inspection', inherited: false },
    ],
  },
  {
    popular: false,
    name: 'Complete Assurance Package',
    startingAt: '950',
    description: "Our most comprehensive offering adds mold air sampling using the AirOCell method for total peace of mind.",
    includes: [
      { label: 'General Home Inspection', inherited: true },
      { label: '4-Point Inspection Form', inherited: true },
      { label: 'Wind Mitigation OIR-B1-1802 Form', inherited: true },
      { label: 'Lateral Sewer Scope Inspection', inherited: true },
      { label: 'Thermal Scope Inspection', inherited: true },
      { label: 'Air Sampling AirOCell Method', inherited: false },
    ],
  },
];
---

<!-- ====== Service Bundles Section Start -->
<section id="packages" class="relative py-20 lg:py-[120px] dark:bg-dark">

  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-24 left-1/2 h-72 w-[42rem] -translate-x-1/2 rounded-full bg-primary/8 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-56 w-56 rounded-full bg-secondary/5 blur-2xl"></div>
  </div>

  <div class="container relative">

    <div class="mx-auto mb-12 max-w-2xl text-center lg:mb-[70px]">
      <span class="mb-3 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
        Inspection Packages
      </span>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
        Choose the Right Package for Your Home
      </h2>
      <p class="mt-4 text-base leading-relaxed text-body-color dark:text-dark-6">
        Every package includes a same-day digital report. Prices start at the amounts shown and vary by property square footage.
      </p>
    </div>

    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-3 lg:gap-8">
      {bundles.map((bundle) => (
        <div class={`relative flex flex-col rounded-2xl border shadow-sm backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-lg ${bundle.popular ? 'border-primary/60 bg-white ring-2 ring-primary/30 hover:ring-primary/50 dark:bg-dark/80' : 'border-black/5 bg-white/70 dark:border-white/10 dark:bg-dark/40'}`}>

          {bundle.popular && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-primary px-4 py-1 text-xs font-bold uppercase tracking-widest text-white shadow">
                <svg class="h-3 w-3" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
                  <path d="M6 1l1.236 2.504L10 3.82l-2 1.948.472 2.752L6 7.1 3.528 8.52 4 5.768 2 3.82l2.764-.316L6 1z" />
                </svg>
                Most Popular
              </span>
            </div>
          )}

          <div class="flex flex-1 flex-col p-7 pt-9">

            <h3 class="text-xl font-bold text-dark dark:text-white">{bundle.name}</h3>

            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-xs font-semibold uppercase tracking-wide text-body-color dark:text-dark-6">Starting at</span>
              <span class="text-4xl font-extrabold tracking-tight text-dark dark:text-white">${bundle.startingAt}</span>
            </div>
            <p class="mt-1 text-[11px] text-body-color/80 dark:text-dark-6">
              Price varies based on property square footage.
            </p>

            <p class="mt-4 text-sm leading-relaxed text-body-color dark:text-dark-6">{bundle.description}</p>

            <div class="my-6 border-t border-black/5 dark:border-white/10"></div>

            <ul class="flex-1 space-y-3">
              {bundle.includes.map((item) => (
                <li class="flex items-start gap-2.5">
                  <span class={`mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full ${item.inherited ? 'bg-dark/5 dark:bg-white/10' : 'bg-secondary/15'}`}>
                    <svg
                      class={`h-2.5 w-2.5 ${item.inherited ? 'text-dark/30 dark:text-white/30' : 'text-secondary'}`}
                      viewBox="0 0 10 10"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M1.5 5.5l2.5 2.5 4.5-5" />
                    </svg>
                  </span>
                  <span class={`text-sm ${item.inherited ? 'text-body-color/70 dark:text-dark-6/80' : 'font-medium text-dark dark:text-white'}`}>
                    {item.label}
                  </span>
                </li>
              ))}
            </ul>

            <div class="mt-8">
              <a
                href="/schedule"
                class={`flex w-full items-center justify-center gap-2 rounded-lg px-6 py-3.5 text-sm font-semibold shadow-sm transition-all duration-300 ease-in-out hover:-translate-y-[1px] hover:shadow-md focus-visible:outline-none focus-visible:ring-2 ${bundle.popular ? 'bg-primary text-white hover:bg-blue-700 focus-visible:ring-primary/50' : 'bg-dark/5 text-dark hover:bg-primary hover:text-white dark:bg-white/10 dark:text-white dark:hover:bg-primary focus-visible:ring-primary/40'}`}
              >
                Book This Package
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
              <p class="mt-2.5 text-center text-[11px] leading-tight text-body-color/60 dark:text-dark-6/60">
                On the scheduling page, select each included service from the dropdown menu.
              </p>
            </div>

          </div>
        </div>
      ))}
    </div>

    <p class="mx-auto mt-6 max-w-xl text-center text-sm text-body-color dark:text-dark-6">
      Need just one service? Standalone inspections start at $325 — use the <a href="/#getquote" class="font-semibold text-primary hover:underline">Get Quote tool below</a> for an instant estimate tailored to your property.
    </p>

    <p class="mx-auto mt-4 max-w-xl text-center text-sm text-body-color dark:text-dark-6">
      Not sure which package fits your needs?
      <a href="/contact" class="font-semibold text-primary hover:underline">Contact us</a>
      and we will walk you through the right option for your property.
    </p>

  </div>
</section>
<!-- ====== Service Bundles Section End -->
