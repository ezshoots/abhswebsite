---
const testimonials = [
  {
    authorName: 'David Powell',
    date: '2 weeks ago',
    message: 'Above and beyond home inspector who does the work well and educates the homeowner every step of the process.',
  },
  {
    authorName: 'Carlo Gervasi',
    date: '2 weeks ago',
    message: 'Very thorough in their inspection. I would highly recommend this company!',
  },
  {
    authorName: 'Tim Gramlich',
    date: '19 weeks ago',
    message: 'Very informative. Explained everything in terms we can understand. On-time and efficient.',
  },
  {
    authorName: 'Sean Hodge',
    date: '14 weeks ago',
    message: 'This was our first Florida home so we wanted to make sure we got the right person. We could not have been happier with Above and Beyond Home Solutions!! They were VERY thorough and communicative every step of the way. The reports were extensive, descriptive and very easy to sort through. I cannot say enough good things about these guys and would recommend them to everyone!',
  },
  {
    authorName: 'Mitch',
    date: '34 weeks ago',
    message: 'Yevgen was extremely detailed and answered all of my questions while at the inspection. He also sent the report shortly after payment and continued answering questions via email. Overall a great experience and would highly recommend.',
  },
  {
    authorName: 'C A',
    date: '6 weeks ago',
    message: 'I cannot recommend Yevgen highly enough! His exceptional expertise in the building industry went above and beyond my expectations. He discovered that the property I was interested in was actually a wood frame, contrary to what had been advertised. This crucial insight saved me from potentially spending hundreds of thousands of dollars. Above and beyond his impressive knowledge, he was consistently friendly and accommodating.',
  },
  {
    authorName: 'Jeanie Newsom',
    date: '5 weeks ago',
    message: 'I am from Ohio and just bought a home in North Fort Myers. Eugene took his time and did an outstanding job explaining everything to ensure I understood the report. What shocked me most — when it came time to pay, he told me he had made a mistake on the mileage and lowered the bill. He could have said nothing since I already agreed on the price. Not only does he do a thorough inspection, he is honest too.',
  },
  {
    authorName: 'Delva Keevonya',
    date: '6 weeks ago',
    message: "Yevgen is truly heaven-sent. He went above and beyond to ensure my fiancé and I received a thorough inspection, and he stood firm on the items that needed to be addressed. It's rare to find someone so honest and dependable in this business, but Yevgen is truly one of a kind. You absolutely won't go wrong choosing him as your inspector!",
  },
  {
    authorName: 'Kevin',
    date: '',
    message: "We purchased our first home and were lucky enough to find Eugene. The company name matches his work ethic. He took a full 3 hours and went over every crook and cranny. He was also very honest about the types of inspections we needed — he could have easily charged us for additional ones but didn't. He is an honest, hard working man that isn't money hungry. Any inspection required I will go through this company. 5/5.",
  },
  {
    authorName: 'Michael Ghiris',
    date: '10 weeks ago',
    message: 'These guys were top notch! Noticed things on my home I would never expect. Eugene is honest, thorough, and takes his time with his work. Would recommend to anyone!!',
  },
  {
    authorName: 'Any Areli Garcia',
    date: '13 weeks ago',
    message: 'Thank you again Above and Beyond for another wonderful experience. The inspections are very thorough and we are grateful that you answer all our questions. Communication with us is very responsive and quick. We look forward to doing business with you again!',
  },
];

const googleLogoSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="28" height="28"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>`;
---

<section id="testimonials" class="py-20 md:py-[120px] bg-gray-1 dark:bg-dark-2 overflow-hidden">
  <div class="container px-4">
    <div class="mx-auto mb-12 max-w-[485px] text-center">
      <span class="block mb-2 text-lg font-semibold text-primary">Testimonials</span>
      <h2 class="text-dark dark:text-white mb-3 text-3xl leading-[1.2] font-bold sm:text-4xl md:text-[40px]">
        What our Clients Say
      </h2>
      <p class="text-base text-body-color dark:text-dark-6">
        Real reviews from real homeowners across Southwest Florida.
      </p>
    </div>
  </div>

  <!-- Scrolling track -->
  <div class="review-track-wrapper">
    <div class="review-track">
      {testimonials.map((t) => (
        <div class="review-card">
          <!-- Stars -->
          <div class="flex items-center gap-[3px] mb-3">
            {[...Array(5)].map(() => (
              <svg class="fill-[#FBB040]" width="16" height="15" viewBox="0 0 18 16" xmlns="http://www.w3.org/2000/svg">
                <path d="M8.94043 0.360474L10.9477 6.06481H17.4433L12.1882 9.59028L14.1955 15.2946L8.94043 11.7691L3.68538 15.2946L5.69263 9.59028L0.437576 6.06481H6.93318L8.94043 0.360474Z" />
              </svg>
            ))}
          </div>
          <!-- Message -->
          <p class="text-sm leading-relaxed text-body-color dark:text-dark-6 mb-5 line-clamp-4">{t.message}</p>
          <!-- Author -->
          <div class="flex items-center gap-3 mt-auto">
            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-white border border-gray-100 dark:border-white/10 shadow-sm">
              <Fragment set:html={googleLogoSvg} />
            </div>
            <div>
              <p class="text-sm font-semibold text-dark dark:text-white">{t.authorName}</p>
              <p class="text-xs text-body-color dark:text-dark-6">Google Review{t.date ? ` · ${t.date}` : ''}</p>
            </div>
          </div>
        </div>
      ))}
      {/* Duplicate for seamless loop */}
      {testimonials.map((t) => (
        <div class="review-card" aria-hidden="true">
          <div class="flex items-center gap-[3px] mb-3">
            {[...Array(5)].map(() => (
              <svg class="fill-[#FBB040]" width="16" height="15" viewBox="0 0 18 16" xmlns="http://www.w3.org/2000/svg">
                <path d="M8.94043 0.360474L10.9477 6.06481H17.4433L12.1882 9.59028L14.1955 15.2946L8.94043 11.7691L3.68538 15.2946L5.69263 9.59028L0.437576 6.06481H6.93318L8.94043 0.360474Z" />
              </svg>
            ))}
          </div>
          <p class="text-sm leading-relaxed text-body-color dark:text-dark-6 mb-5 line-clamp-4">{t.message}</p>
          <div class="flex items-center gap-3 mt-auto">
            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-white border border-gray-100 dark:border-white/10 shadow-sm">
              <Fragment set:html={googleLogoSvg} />
            </div>
            <div>
              <p class="text-sm font-semibold text-dark dark:text-white">{t.authorName}</p>
              <p class="text-xs text-body-color dark:text-dark-6">Google Review{t.date ? ` · ${t.date}` : ''}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- View more on Google -->
  <div class="flex justify-center mt-10">
    <a
      href="https://share.google/HI4hykJ6nx7rj3yXi"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm font-medium text-body-color dark:text-dark-6 hover:text-primary transition-colors duration-200"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
      </svg>
      View all reviews on Google
    </a>
  </div>
</section>

<style>
  .review-track-wrapper {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  .review-track {
    display: flex;
    align-items: stretch;
    gap: 1.5rem;
    width: max-content;
    padding: 1rem 0;
    animation: review-scroll 60s linear infinite;
  }

  .review-track:hover {
    animation-play-state: paused;
  }

  @keyframes review-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .review-card {
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    width: 300px;
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
  }

  :global(.dark) .review-card {
    background: #1e2d3d;
  }
</style>
