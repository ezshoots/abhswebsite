---
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import CTAsection from '../components/CTAsection.astro';
import Layout from '../layouts/Layout.astro';

const included = [
  {
    title: 'Roof & Attic',
    description:
      'We inspect roof coverings, flashings, gutters, ventilation, and attic insulation. In Southwest Florida\'s climate, roof condition directly impacts your insurance rates and storm readiness. We document everything clearly.',
    icon: `<path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: 'Structural Components',
    description:
      'We evaluate the foundation, framing, walls, floors, and ceilings for signs of settlement, cracking, moisture intrusion, or damage. These are critical checks in Florida\'s high-humidity, hurricane-prone environment.',
    icon: `<path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
  },
  {
    title: 'Electrical Systems',
    description:
      'We inspect the service panel, wiring, outlets, GFCI protection, and visible components for safety hazards. Outdated or improperly installed electrical systems are among the most common findings in older Florida homes.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
  {
    title: 'Plumbing',
    description:
      'We assess supply lines, drain lines, water heater condition, fixtures, and visible pipe materials. We note aging galvanized or polybutylene piping that can affect insurability and flag active leaks or signs of prior water damage.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>`,
  },
  {
    title: 'HVAC',
    description:
      'In the Florida heat, your air conditioning system is essential. We test heating and cooling equipment for proper operation, inspect ductwork and air handlers, and note age and condition so you know what to expect.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m1.636-6.364l.707.707M12 21v-1m-6.364-1.636l.707-.707M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  },
  {
    title: 'Interior & Exterior',
    description:
      'We walk the entire property, including doors, windows, siding, driveways, grading, decks, and interior rooms, checking for water intrusion, pest damage, cosmetic issues, and safety concerns that affect the home\'s value and livability.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>`,
  },
];

const steps = [
  { number: '01', title: 'Book Online', description: 'Schedule in minutes at your convenience through our online booking system. Pick a date and time that works for you. No phone tag required.' },
  { number: '02', title: 'On-Site Inspection', description: 'Our licensed inspector arrives on time and conducts a comprehensive walkthrough of the home, typically lasting 2–4 hours depending on the size and condition of the property.' },
  { number: '03', title: 'Receive Your Report', description: 'Your detailed digital report, complete with photos, descriptions, and recommendations, is delivered the same day so you can act quickly during your inspection period.' },
];
---

<Layout
  title="General Home Inspection | Above and Beyond Home Solutions"
  description="Professional general home inspections in Fort Myers, Cape Coral, Naples, Port Charlotte, Sarasota, and across Southwest Florida. InterNACHI certified. Same-day reports."
>
  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "General Home Inspection",
    "serviceType": "General Home Inspection",
    "description": "Professional general home inspections in Southwest Florida. We inspect the roof, attic, structural components, electrical systems, plumbing, HVAC, and interior/exterior. InterNACHI certified. Same-day digital reports.",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Above and Beyond Home Solutions, LLC",
      "url": "https://www.abovebeyondhomesolutions.com"
    },
    "areaServed": ["Fort Myers, FL","Cape Coral, FL","Lehigh Acres, FL","Naples, FL","North Port, FL","Sarasota, FL","Port Charlotte, FL","Punta Gorda, FL","Bonita Springs, FL","Estero, FL","Marco Island, FL"],
    "url": "https://www.abovebeyondhomesolutions.com/generalhomeinspection"
  }
  </script>
  <Breadcrumb pageTitle="General Home Inspection">
    <Fragment slot="title">General Home Inspection</Fragment>
  </Breadcrumb>

  <!-- ====== Overview Section Start -->
  <section class="py-20 dark:bg-dark lg:py-[120px]">
    <div class="container">
      <div class="-mx-4 flex flex-wrap items-center">

        <!-- Text column -->
        <div class="w-full px-4 lg:w-1/2">
          <div class="mb-12 lg:mb-0 lg:pr-10">
            <span class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
              Our Most Popular Service
            </span>
            <h2 class="mb-5 mt-3 text-3xl font-bold text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
              A Thorough Inspection You Can Rely On
            </h2>
            <p class="mb-5 text-base leading-relaxed text-body-color dark:text-dark-6">
              Whether you're buying a home in Fort Myers, Cape Coral, Naples, Port Charlotte, Sarasota, North Port, or anywhere across Southwest Florida, a thorough general home inspection gives you an honest picture of the property before you commit. We evaluate every major system and component from roof to foundation.
            </p>
            <p class="mb-8 text-base leading-relaxed text-body-color dark:text-dark-6">
              Our InterNACHI certified inspector uses thermal imaging, moisture meters, and advanced diagnostic tools to find issues that aren't always visible to the naked eye. You'll receive a clear, photo-documented digital report the same day so you can negotiate repairs, plan for maintenance, or walk away with confidence.
            </p>
            <a
              href="/schedule"
              class="inline-flex items-center justify-center rounded-md bg-primary px-7 py-3 text-base font-medium text-white shadow-sm transition-all duration-300 ease-in-out hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
            >
              Schedule an Inspection
            </a>
          </div>
        </div>

        <!-- Image / stat column -->
        <div class="w-full px-4 lg:w-1/2">
          <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary/10 to-primary/5 p-1 ring-1 ring-primary/20 dark:from-primary/20 dark:to-primary/10">
            <img
              src="/assets/blog/blog-details-01.jpg"
              alt="Home inspector reviewing property"
              class="w-full rounded-xl object-cover"
              style="aspect-ratio: 16/10;"
            />
          </div>

          <!-- Stat strip -->
          <div class="mt-6 grid grid-cols-3 divide-x divide-stroke dark:divide-dark-3 rounded-xl border border-stroke dark:border-dark-3 bg-white dark:bg-dark-2">
            <div class="px-5 py-4 text-center">
              <p class="text-2xl font-bold text-dark dark:text-white">Modern Tools</p>
              <p class="mt-1 text-xs text-body-color dark:text-dark-6">Thermal Imaging</p>
            </div>
            <div class="px-5 py-4 text-center">
              <p class="text-2xl font-bold text-dark dark:text-white">Same Day</p>
              <p class="mt-1 text-xs text-body-color dark:text-dark-6">Reports</p>
            </div>
            <div class="px-5 py-4 text-center">
              <p class="text-2xl font-bold text-dark dark:text-white">5★</p>
              <p class="mt-1 text-xs text-body-color dark:text-dark-6">Rated</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- ====== Overview Section End -->

  <!-- ====== What's Included Section Start -->
  <section class="bg-gray-1 py-20 dark:bg-dark-2 lg:py-[120px]">
    <div class="container">
      <div class="mx-auto mb-12 max-w-2xl text-center lg:mb-[70px]">
        <span class="mb-3 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
          Full Coverage
        </span>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
          What's Included in Your Inspection
        </h2>
        <p class="mt-4 text-base leading-relaxed text-body-color dark:text-dark-6">
          Every inspection covers all major systems and components of the home. Below is a breakdown of what's evaluated during your inspection. Nothing gets skipped.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
        {included.map((item) => (
          <div class="group rounded-2xl border border-black/5 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:ring-1 hover:ring-primary/20 dark:border-white/10 dark:bg-dark">
            <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 ring-1 ring-primary/20 transition-transform duration-300 group-hover:scale-[1.05]">
              <svg
                class="h-6 w-6 text-primary"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <Fragment set:html={item.icon} />
              </svg>
            </div>
            <h3 class="mb-3 text-lg font-semibold text-dark dark:text-white">{item.title}</h3>
            <p class="text-sm leading-relaxed text-body-color dark:text-dark-6">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <!-- ====== What's Included Section End -->

  <!-- ====== How It Works Section Start -->
  <section class="py-20 dark:bg-dark lg:py-[120px]">
    <div class="container">
      <div class="mx-auto mb-12 max-w-2xl text-center lg:mb-[70px]">
        <span class="mb-3 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
          Simple Process
        </span>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
          How It Works
        </h2>
        <p class="mt-4 text-base leading-relaxed text-body-color dark:text-dark-6">
          Getting your inspection scheduled is simple. Here's what to expect from start to finish.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {steps.map((step) => (
          <div class="relative text-center">
            <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 ring-2 ring-primary/20">
              <span class="text-2xl font-bold text-primary">{step.number}</span>
            </div>
            <h3 class="mb-3 text-xl font-semibold text-dark dark:text-white">{step.title}</h3>
            <p class="text-sm leading-relaxed text-body-color dark:text-dark-6">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <!-- ====== How It Works Section End -->

  <!-- ====== Why It Matters Section Start -->
  <section class="bg-gray-1 py-20 dark:bg-dark-2 lg:py-[120px]">
    <div class="container">
      <div class="-mx-4 flex flex-wrap items-center">

        <div class="w-full px-4 lg:w-1/2">
          <div class="relative overflow-hidden rounded-2xl">
            <img
              src="/assets/blog/blog-01.webp"
              alt="Inspector using thermal camera"
              class="w-full rounded-2xl object-cover"
              style="aspect-ratio: 4/3;"
            />
            <!-- badge overlay -->
            <div class="absolute bottom-4 left-4 flex items-center gap-3 rounded-xl bg-white/90 px-4 py-3 shadow-md backdrop-blur dark:bg-dark/90">
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-primary/10">
                <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <div>
                <p class="text-sm font-semibold text-dark dark:text-white">InterNACHI Certified</p>
                <p class="text-xs text-body-color dark:text-dark-6">Licensed & Insured</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full px-4 lg:w-1/2">
          <div class="mt-10 lg:mt-0 lg:pl-12">
            <span class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
              Why It Matters
            </span>
            <h2 class="mb-5 mt-3 text-3xl font-bold text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
              Protect Your Investment Before You Sign
            </h2>
            <p class="mb-5 text-base leading-relaxed text-body-color dark:text-dark-6">
              A home inspection isn't just a formality. It's one of the most important steps in any real estate transaction. In Florida's market, waiving an inspection or choosing a cheap one can cost far more later in surprise repairs, insurance complications, or safety hazards you didn't see coming.
            </p>
            <p class="mb-8 text-base leading-relaxed text-body-color dark:text-dark-6">
              At Above and Beyond Home Solutions, we treat every home as if we're buying it ourselves. From Alva to Bonita Springs, Lehigh Acres to Venice, our thorough process ensures nothing gets overlooked so you go into your purchase fully informed.
            </p>

            <ul class="mb-8 space-y-3">
              {[
                'Detailed digital report delivered same day',
                'Thermal imaging and moisture detection tools',
                'Clear photo documentation of every finding',
                'Plain-language explanations, no jargon',
              ].map((point) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-primary/10">
                    <svg class="h-3 w-3 text-primary" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                  </span>
                  <span class="text-base text-body-color dark:text-dark-6">{point}</span>
                </li>
              ))}
            </ul>

            <a
              href="/schedule"
              class="inline-flex items-center justify-center rounded-md bg-primary px-7 py-3 text-base font-medium text-white shadow-sm transition-all duration-300 ease-in-out hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
            >
              Book Your Inspection
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- ====== Why It Matters Section End -->

  <CTAsection />
</Layout>
