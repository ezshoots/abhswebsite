---
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import CTAsection from '../components/CTAsection.astro';
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'General Home Inspection',
    description: 'Comprehensive inspection of roof, structure, electrical, plumbing, HVAC, interior, and exterior. Same-day digital report with annotated photos.',
    href: '/generalhomeinspection',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: '4-Point & Wind Mitigation',
    description: 'Required by most Florida insurers for homes 20+ years old. We document roof, electrical, plumbing, and HVAC to help you qualify for lower premiums.',
    href: '/4pointandwind',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
  {
    title: 'Lateral Sewer Scope',
    description: 'Camera inspection of the sewer line from your home to the street. Critical for North Port\'s older CBS homes and any property with mature trees near sewer lines.',
    href: '/services/lateral-sewer-scope',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`,
  },
  {
    title: 'Water & Air Quality Testing',
    description: 'Well water testing, mold screening, and air quality sampling. Important for North Port properties on well water or with any history of moisture issues.',
    href: '/services/water-air-quality',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>`,
  },
];

const commonIssues = [
  {
    issue: 'Roof Wear & Storm Damage',
    detail: 'North Port\'s rapid growth brought many homes built in the 1980s and 1990s that now have aging roofs. We document condition, estimate remaining life, and flag anything that may affect insurability.',
  },
  {
    issue: 'Moisture & Mold',
    detail: 'Sarasota County\'s humidity combined with older HVAC systems and poor attic ventilation creates ideal conditions for mold. We identify moisture intrusion points before they become expensive repairs.',
  },
  {
    issue: 'New Construction Defects',
    detail: 'Wellen Park and other North Port developments are booming. New doesn\'t mean perfect — we find framing errors, improper flashing, and missing code items that builders sometimes miss.',
  },
  {
    issue: 'Electrical Panel Issues',
    detail: 'Homes from the 1970s–1990s in North Port often have Federal Pacific or Zinsco panels that insurers won\'t cover. We identify these and other wiring concerns that affect safety and insurability.',
  },
  {
    issue: 'Flood Zone & Drainage',
    detail: 'Portions of North Port sit in AE and X flood zones. We note drainage conditions, grading issues, and any signs of prior flooding that could affect insurance costs or resale value.',
  },
  {
    issue: 'Plumbing Material',
    detail: 'Polybutylene and galvanized steel piping are still common in older North Port homes. We identify pipe materials so you know replacement costs before closing.',
  },
];
---

<Layout
  title="Home Inspector in North Port, FL | Above and Beyond Home Solutions"
  description="Licensed home inspector serving North Port, FL. Comprehensive inspections, 4-point, wind mitigation, sewer scope & more. InterNACHI certified, same-day reports."
>
  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Home Inspection in North Port, FL",
    "serviceType": "Home Inspection",
    "description": "Professional home inspections serving North Port, Florida. General home inspection, 4-point, wind mitigation, lateral sewer scope, water and air quality testing. InterNACHI certified inspector, same-day digital reports.",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Above and Beyond Home Solutions, LLC",
      "url": "https://www.abovebeyondhomesolutions.com",
      "telephone": "+12394163505",
      "license": "Florida Home Inspector License HI16270"
    },
    "areaServed": {
      "@type": "City",
      "name": "North Port",
      "containedInPlace": {
        "@type": "State",
        "name": "Florida"
      }
    },
    "url": "https://www.abovebeyondhomesolutions.com/home-inspector-north-port"
  }
  </script>

  <Breadcrumb>
    <Fragment slot="title">Home Inspector in North Port, FL</Fragment>
  </Breadcrumb>

  <!-- Hero -->
  <section class="bg-white dark:bg-dark py-16 lg:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl text-center">
        <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
          Sarasota County · North Port, FL
        </span>
        <h1 class="mb-5 text-4xl font-extrabold tracking-tight text-dark dark:text-white sm:text-5xl">
          Home Inspector in North Port, FL
        </h1>
        <p class="mb-8 text-lg leading-relaxed text-body-color dark:text-dark-6">
          Above and Beyond Home Solutions provides thorough, same-day home inspections throughout North Port and Sarasota County. Whether you're buying a resale home in an established neighborhood or a brand-new build in Wellen Park, our InterNACHI certified inspectors give you the full picture before you close.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/schedule"
            class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-4 text-base font-semibold text-white shadow-sm transition-all duration-300 hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md"
          >
            Book Your North Port Inspection
          </a>
          <a
            href="tel:+12394163505"
            class="inline-flex items-center justify-center rounded-md border border-primary/30 px-8 py-4 text-base font-semibold text-primary transition-all duration-300 hover:bg-primary/5"
          >
            Call (239) 416-3505
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="bg-slate-50 dark:bg-dark-2 py-10">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {[
          { label: 'InterNACHI Certified', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>` },
          { label: 'License #HI16270', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>` },
          { label: 'Same-Day Reports', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>` },
          { label: 'Locally Owned', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>` },
        ].map(item => (
          <div class="flex flex-col items-center gap-2 rounded-xl bg-white dark:bg-dark p-4 text-center shadow-sm">
            <svg class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={item.icon} />
            <span class="text-sm font-semibold text-dark dark:text-white">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-white dark:bg-dark py-16 lg:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="mb-4 text-3xl font-bold text-dark dark:text-white sm:text-4xl">
          Inspection Services in North Port
        </h2>
        <p class="text-base text-body-color dark:text-dark-6">
          From standard buyer inspections to insurance-required reports, we cover every service North Port homebuyers and sellers need.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map(service => (
          <a
            href={service.href}
            class="group flex flex-col rounded-xl border border-stroke bg-white dark:border-dark-3 dark:bg-dark-2 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-primary/30"
          >
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={service.icon} />
            </div>
            <h3 class="mb-2 text-lg font-semibold text-dark dark:text-white">{service.title}</h3>
            <p class="flex-1 text-sm text-body-color dark:text-dark-6">{service.description}</p>
            <span class="mt-4 text-sm font-semibold text-primary">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Common Issues in North Port -->
  <section class="bg-slate-50 dark:bg-dark-2 py-16 lg:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="mb-4 text-3xl font-bold text-dark dark:text-white sm:text-4xl">
          Common Issues Found in North Port Homes
        </h2>
        <p class="text-base text-body-color dark:text-dark-6">
          North Port's unique mix of older CBS construction and rapid new development means our inspectors know exactly what to look for in this market.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {commonIssues.map(item => (
          <div class="rounded-xl border border-stroke bg-white dark:border-dark-3 dark:bg-dark p-6 shadow-sm">
            <div class="mb-3 flex items-center gap-3">
              <div class="h-2.5 w-2.5 rounded-full bg-primary flex-shrink-0"></div>
              <h3 class="font-semibold text-dark dark:text-white">{item.issue}</h3>
            </div>
            <p class="text-sm text-body-color dark:text-dark-6">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About North Port / Why Inspect Here -->
  <section class="bg-white dark:bg-dark py-16 lg:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-3xl font-bold text-dark dark:text-white">
          Why Home Inspections Matter in North Port
        </h2>
        <div class="space-y-4 text-base leading-relaxed text-body-color dark:text-dark-6">
          <p>
            North Port has been one of Florida's fastest-growing cities for over a decade. That growth brings tremendous opportunity — and real risk. Buyers are competing for homes in established neighborhoods like Jockey Club and Bobcat Trail alongside brand-new builds in Wellen Park. In both cases, a thorough inspection is your most important protection.
          </p>
          <p>
            Older homes in North Port — particularly those built in the 1980s and early 1990s — often have aging roofs approaching their insurance renewal deadline, outdated electrical panels, and plumbing materials that lenders and insurers flag. Our inspectors know these homes well and document every concern clearly so you can negotiate confidently or walk away with full information.
          </p>
          <p>
            New construction is no guarantee of quality. We routinely find framing defects, improper attic ventilation, inadequate waterproofing at penetrations, and missing code items in newly completed North Port homes. A new-construction inspection before you close — or before your builder's warranty expires — can save you thousands.
          </p>
          <p>
            We serve all of North Port including Wellen Park, The Cove at West Villages, Bobcat Trail, Heron Creek, and surrounding Sarasota County communities.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/schedule"
            class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-4 text-base font-semibold text-white shadow-sm transition-all duration-300 hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md"
          >
            Schedule Your North Port Inspection
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTAsection />
</Layout>
