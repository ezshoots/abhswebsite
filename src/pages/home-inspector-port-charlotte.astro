---
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import CTAsection from '../components/CTAsection.astro';
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'General Home Inspection',
    description: 'Complete inspection of roof, structure, electrical, plumbing, HVAC, interior, and exterior. Same-day digital report with annotated photos.',
    href: '/generalhomeinspection',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: '4-Point & Wind Mitigation',
    description: 'Most Port Charlotte homes 20+ years old require these reports for insurance. We deliver insurer-accepted reports to help you get and keep coverage.',
    href: '/4pointandwind',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
  {
    title: 'Lateral Sewer Scope',
    description: 'Camera inspection of your sewer line. Critical for Port Charlotte\'s older homes and canal-front properties where root intrusion is common.',
    href: '/services/lateral-sewer-scope',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`,
  },
  {
    title: 'Home Watch Services',
    description: 'Scheduled property checks with photo reports for snowbirds and seasonal residents. Port Charlotte\'s large seasonal population makes this service especially popular.',
    href: '/services/home-watch',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`,
  },
];

const commonIssues = [
  {
    issue: 'Aging Roofs & Insurance Challenges',
    detail: 'A large share of Port Charlotte homes were built in the 1970s–1990s. Roofs on these homes are at or past the age where Florida insurers require 4-Point inspections or refuse new policies. We document condition clearly to help you navigate insurer requirements.',
  },
  {
    issue: 'Canal-Front Seawall & Dock Condition',
    detail: 'Charlotte County has hundreds of miles of canals. We inspect seawalls, docks, boat lifts, and waterfront structures for deterioration, improper installation, and safety hazards — items a standard inspection often glosses over.',
  },
  {
    issue: 'Polybutylene & Galvanized Plumbing',
    detail: 'Polybutylene pipe — installed in many 1980s–1990s homes — is prone to failure and uninsurable with many carriers. We identify pipe materials throughout the home so you know what you\'re buying.',
  },
  {
    issue: 'Electrical Panel Hazards',
    detail: 'Federal Pacific Stab-Lok and Zinsco panels are found in a significant number of Port Charlotte homes. These are fire hazards and insurance liabilities. We flag them and explain your options.',
  },
  {
    issue: 'Seasonal Home Deferred Maintenance',
    detail: 'Many Port Charlotte homes are snowbird properties that sit vacant for months. Deferred maintenance, pest activity, roof wear from UV, and HVAC issues from infrequent use are common findings on these properties.',
  },
  {
    issue: 'Hurricane Damage & Prior Repairs',
    detail: 'Port Charlotte was directly impacted by Hurricane Ian in 2022. We look for evidence of incomplete repairs, improper patching, and hidden moisture damage that may have been missed or left unaddressed.',
  },
];
---

<Layout
  title="Home Inspector in Port Charlotte, FL | Above and Beyond Home Solutions"
  description="Licensed home inspector serving Port Charlotte, FL. General inspections, 4-point, wind mitigation, sewer scope & home watch. InterNACHI certified, same-day reports."
>
  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Home Inspection in Port Charlotte, FL",
    "serviceType": "Home Inspection",
    "description": "Professional home inspections serving Port Charlotte, Florida. General home inspection, 4-point, wind mitigation, lateral sewer scope, and home watch services. InterNACHI certified inspector, same-day digital reports.",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Above and Beyond Home Solutions, LLC",
      "url": "https://www.abovebeyondhomesolutions.com",
      "telephone": "+12394163505",
      "license": "Florida Home Inspector License HI16270"
    },
    "areaServed": {
      "@type": "City",
      "name": "Port Charlotte",
      "containedInPlace": {
        "@type": "State",
        "name": "Florida"
      }
    },
    "url": "https://www.abovebeyondhomesolutions.com/home-inspector-port-charlotte"
  }
  </script>

  <Breadcrumb>
    <Fragment slot="title">Home Inspector in Port Charlotte, FL</Fragment>
  </Breadcrumb>

  <!-- Hero -->
  <section class="bg-white dark:bg-dark py-16 lg:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl text-center">
        <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
          Charlotte County · Port Charlotte, FL
        </span>
        <h1 class="mb-5 text-4xl font-extrabold tracking-tight text-dark dark:text-white sm:text-5xl">
          Home Inspector in Port Charlotte, FL
        </h1>
        <p class="mb-8 text-lg leading-relaxed text-body-color dark:text-dark-6">
          Above and Beyond Home Solutions provides comprehensive home inspections throughout Port Charlotte and Charlotte County. With hundreds of miles of canals, a large stock of 1970s–1990s homes, and a significant seasonal population, Port Charlotte demands an inspector who knows the local market. That's us.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/schedule"
            class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-4 text-base font-semibold text-white shadow-sm transition-all duration-300 hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md"
          >
            Book Your Port Charlotte Inspection
          </a>
          <a
            href="tel:+12394163505"
            class="inline-flex items-center justify-center rounded-md border border-primary/30 px-8 py-4 text-base font-semibold text-primary transition-all duration-300 hover:bg-primary/5"
          >
            Call (239) 416-3505
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="bg-slate-50 dark:bg-dark-2 py-10">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {[
          { label: 'InterNACHI Certified', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>` },
          { label: 'License #HI16270', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>` },
          { label: 'Same-Day Reports', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>` },
          { label: 'Locally Owned', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>` },
        ].map(item => (
          <div class="flex flex-col items-center gap-2 rounded-xl bg-white dark:bg-dark p-4 text-center shadow-sm">
            <svg class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={item.icon} />
            <span class="text-sm font-semibold text-dark dark:text-white">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-white dark:bg-dark py-16 lg:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="mb-4 text-3xl font-bold text-dark dark:text-white sm:text-4xl">
          Inspection Services in Port Charlotte
        </h2>
        <p class="text-base text-body-color dark:text-dark-6">
          From buyer's inspections to insurance-required reports and seasonal home monitoring, we cover what Port Charlotte homeowners need.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map(service => (
          <a
            href={service.href}
            class="group flex flex-col rounded-xl border border-stroke bg-white dark:border-dark-3 dark:bg-dark-2 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-primary/30"
          >
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={service.icon} />
            </div>
            <h3 class="mb-2 text-lg font-semibold text-dark dark:text-white">{service.title}</h3>
            <p class="flex-1 text-sm text-body-color dark:text-dark-6">{service.description}</p>
            <span class="mt-4 text-sm font-semibold text-primary">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Common Issues -->
  <section class="bg-slate-50 dark:bg-dark-2 py-16 lg:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="mb-4 text-3xl font-bold text-dark dark:text-white sm:text-4xl">
          Common Issues Found in Port Charlotte Homes
        </h2>
        <p class="text-base text-body-color dark:text-dark-6">
          Port Charlotte's older housing stock, extensive canal system, and hurricane history create a distinct set of inspection findings that demand local expertise.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {commonIssues.map(item => (
          <div class="rounded-xl border border-stroke bg-white dark:border-dark-3 dark:bg-dark p-6 shadow-sm">
            <div class="mb-3 flex items-center gap-3">
              <div class="h-2.5 w-2.5 rounded-full bg-primary flex-shrink-0"></div>
              <h3 class="font-semibold text-dark dark:text-white">{item.issue}</h3>
            </div>
            <p class="text-sm text-body-color dark:text-dark-6">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Inspect in Port Charlotte -->
  <section class="bg-white dark:bg-dark py-16 lg:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-3xl font-bold text-dark dark:text-white">
          Why Home Inspections Matter in Port Charlotte
        </h2>
        <div class="space-y-4 text-base leading-relaxed text-body-color dark:text-dark-6">
          <p>
            Port Charlotte was largely developed in the 1970s and 1980s, making it one of Charlotte County's most established communities — and one where home inspection findings are often significant. Aging roofs, outdated electrical panels, older plumbing materials, and post-hurricane damage are not the exception here; they're common.
          </p>
          <p>
            The canal system is one of Port Charlotte's greatest amenities — and one of its biggest inspection challenges. Seawalls, docks, and boat lifts deteriorate in the saltwater environment, and their condition isn't always apparent without a trained inspector. We examine waterfront structures as part of every inspection on canal-front properties.
          </p>
          <p>
            With a large seasonal population that leaves homes unoccupied for months at a time, deferred maintenance and undetected problems are especially common in this market. Whether you're buying a primary residence, a vacation home, or an investment property in Port Charlotte, we give you the complete, unbiased picture.
          </p>
          <p>
            We also serve Punta Gorda, Deep Creek, Murdock, El Jobean, and surrounding Charlotte County communities.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/schedule"
            class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-4 text-base font-semibold text-white shadow-sm transition-all duration-300 hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md"
          >
            Schedule Your Port Charlotte Inspection
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTAsection />
</Layout>
