---
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import CTAsection from '../components/CTAsection.astro';
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'General Home Inspection',
    description: 'Full inspection of roof, structure, electrical, plumbing, HVAC, interior, and exterior. Detailed digital report with photos delivered the same day.',
    href: '/generalhomeinspection',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: '4-Point & Wind Mitigation',
    description: 'Most Punta Gorda homes require these reports to maintain insurance. We deliver accepted reports that help you keep coverage and reduce wind premiums.',
    href: '/4pointandwind',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
  {
    title: 'Lateral Sewer Scope',
    description: 'Camera inspection of the sewer lateral from home to street. Essential for Punta Gorda Isles canal-front properties and any home with large trees over the sewer line.',
    href: '/services/lateral-sewer-scope',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`,
  },
  {
    title: 'Home Watch Services',
    description: 'Scheduled property checks with photo reports for snowbirds and absentee owners. Punta Gorda\'s large seasonal community makes this one of our most requested services.',
    href: '/services/home-watch',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
];

const commonIssues = [
  {
    issue: 'Hurricane Ian Storm Damage',
    detail: 'Punta Gorda took a direct hit from Hurricane Ian in 2022, just as it did from Hurricane Charley in 2004. We look closely for incomplete repairs, improper patching, hidden moisture damage, and mold that developed during the recovery. These things don\'t always show up on the surface.',
  },
  {
    issue: 'Seawall, Dock & Canal Frontage',
    detail: 'Punta Gorda Isles is one of Florida\'s premier boating communities with miles of sailboat-access canals. We inspect seawalls, docks, davits, and boat lifts for corrosion, spalling, and structural deterioration that salt water accelerates.',
  },
  {
    issue: 'Aging Roofs & Insurance',
    detail: 'With many homes from the 1970s–1990s, Punta Gorda has a high proportion of properties approaching the age thresholds where Florida insurers require 4-Point reports or decline new coverage. We document exactly what insurers need to see.',
  },
  {
    issue: 'Electrical Panel Hazards',
    detail: 'Federal Pacific Stab-Lok and Zinsco panels remain common in older Punta Gorda homes. These are fire hazards that most insurers will not cover. We identify them and explain your replacement options.',
  },
  {
    issue: 'Plumbing Materials',
    detail: 'Polybutylene pipe and galvanized steel are still found in many Punta Gorda properties. We document all visible pipe materials throughout the home so you know your replacement risk before closing.',
  },
  {
    issue: 'Deferred Maintenance on Seasonal Homes',
    detail: 'Punta Gorda has a large snowbird population. Homes that sit vacant for months accumulate pest activity, UV roof degradation, HVAC issues from disuse, and minor leaks that go unnoticed. We flag all of it.',
  },
];
---

<Layout
  title="Home Inspector in Punta Gorda, FL | Above and Beyond Home Solutions"
  description="Licensed home inspector serving Punta Gorda, FL. General inspections, 4-point, wind mitigation, sewer scope & home watch. InterNACHI certified, same-day reports."
>
  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Home Inspection in Punta Gorda, FL",
    "serviceType": "Home Inspection",
    "description": "Professional home inspections serving Punta Gorda, Florida. General home inspection, 4-point, wind mitigation, lateral sewer scope, and home watch services. InterNACHI certified inspector, same-day digital reports.",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Above and Beyond Home Solutions, LLC",
      "url": "https://www.abovebeyondhomesolutions.com",
      "telephone": "+12394163505",
      "license": "Florida Home Inspector License HI16270"
    },
    "areaServed": {
      "@type": "City",
      "name": "Punta Gorda",
      "containedInPlace": {
        "@type": "State",
        "name": "Florida"
      }
    },
    "url": "https://www.abovebeyondhomesolutions.com/home-inspector-punta-gorda"
  }
  </script>

  <Breadcrumb>
    <Fragment slot="title">Home Inspector in Punta Gorda, FL</Fragment>
  </Breadcrumb>

  <!-- Hero -->
  <section class="bg-white dark:bg-dark py-16 lg:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl text-center">
        <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
          Charlotte County · Punta Gorda, FL
        </span>
        <h1 class="mb-5 text-4xl font-extrabold tracking-tight text-dark dark:text-white sm:text-5xl">
          Home Inspector in Punta Gorda, FL
        </h1>
        <p class="mb-8 text-lg leading-relaxed text-body-color dark:text-dark-6">
          Above and Beyond Home Solutions delivers thorough, same-day home inspections throughout Punta Gorda and Charlotte County. From the waterfront homes of Punta Gorda Isles to the historic downtown, our InterNACHI certified inspectors know this market well. After two direct hurricane hits, we know exactly what to look for.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/schedule"
            class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-4 text-base font-semibold text-white shadow-sm transition-all duration-300 hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md"
          >
            Book Your Punta Gorda Inspection
          </a>
          <a
            href="tel:+12394163505"
            class="inline-flex items-center justify-center rounded-md border border-primary/30 px-8 py-4 text-base font-semibold text-primary transition-all duration-300 hover:bg-primary/5"
          >
            Call (239) 416-3505
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="bg-slate-50 dark:bg-dark-2 py-10">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {[
          { label: 'InterNACHI Certified', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>` },
          { label: 'License #HI16270', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>` },
          { label: 'Same-Day Reports', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>` },
          { label: 'Locally Owned', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>` },
        ].map(item => (
          <div class="flex flex-col items-center gap-2 rounded-xl bg-white dark:bg-dark p-4 text-center shadow-sm">
            <svg class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={item.icon} />
            <span class="text-sm font-semibold text-dark dark:text-white">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-white dark:bg-dark py-16 lg:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="mb-4 text-3xl font-bold text-dark dark:text-white sm:text-4xl">
          Inspection Services in Punta Gorda
        </h2>
        <p class="text-base text-body-color dark:text-dark-6">
          Every inspection service Punta Gorda homebuyers, sellers, and seasonal property owners need. One team, one call.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map(service => (
          <a
            href={service.href}
            class="group flex flex-col rounded-xl border border-stroke bg-white dark:border-dark-3 dark:bg-dark-2 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-primary/30"
          >
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={service.icon} />
            </div>
            <h3 class="mb-2 text-lg font-semibold text-dark dark:text-white">{service.title}</h3>
            <p class="flex-1 text-sm text-body-color dark:text-dark-6">{service.description}</p>
            <span class="mt-4 text-sm font-semibold text-primary">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Common Issues -->
  <section class="bg-slate-50 dark:bg-dark-2 py-16 lg:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="mb-4 text-3xl font-bold text-dark dark:text-white sm:text-4xl">
          Common Issues Found in Punta Gorda Homes
        </h2>
        <p class="text-base text-body-color dark:text-dark-6">
          Punta Gorda's waterfront lifestyle and hurricane history mean inspection findings here are rarely minor. Here's what comes up most often.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {commonIssues.map(item => (
          <div class="rounded-xl border border-stroke bg-white dark:border-dark-3 dark:bg-dark p-6 shadow-sm">
            <div class="mb-3 flex items-center gap-3">
              <div class="h-2.5 w-2.5 rounded-full bg-primary flex-shrink-0"></div>
              <h3 class="font-semibold text-dark dark:text-white">{item.issue}</h3>
            </div>
            <p class="text-sm text-body-color dark:text-dark-6">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Inspect in Punta Gorda -->
  <section class="bg-white dark:bg-dark py-16 lg:py-20">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-3xl font-bold text-dark dark:text-white">
          Why Home Inspections Matter in Punta Gorda
        </h2>
        <div class="space-y-4 text-base leading-relaxed text-body-color dark:text-dark-6">
          <p>
            Punta Gorda has been through it twice. Hurricane Charley hit in 2004, and Hurricane Ian came back in 2022. That means a lot of homes in this market have been repaired at some point, and the quality of those repairs varies widely. The only way to know what you're actually buying is an independent inspection.
          </p>
          <p>
            Punta Gorda Isles is one of the best boating communities on Florida's west coast. Those canal-front homes come with seawalls, docks, and marine hardware that most standard inspections barely glance at. We look at all of it. The waterfront infrastructure on a canal property can easily be the most expensive thing to fix if something goes wrong.
          </p>
          <p>
            Like a lot of Charlotte County, Punta Gorda has a big snowbird and retiree population. Homes that sit empty for months collect deferred maintenance quietly. Whether you're buying a full-time home or a seasonal retreat, our same-day photo report gives you what you need to negotiate and close without surprises.
          </p>
          <p>
            We serve all of Punta Gorda including Punta Gorda Isles, Burnt Store, Burnt Store Meadows, South Gulf Cove, and surrounding Charlotte County communities.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/schedule"
            class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-4 text-base font-semibold text-white shadow-sm transition-all duration-300 hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md"
          >
            Schedule Your Punta Gorda Inspection
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTAsection />
</Layout>
