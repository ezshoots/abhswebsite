---
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  description="Legal Notice for Above and Beyond Home Solutions. Important legal information and disclaimers."
  title="Legal Notice | Above and Beyond Home Solutions"
>
  <Breadcrumb>
    <Fragment slot="title">Legal Notice</Fragment>
  </Breadcrumb>

  <section class="bg-white dark:bg-dark-2 py-20 lg:py-[110px]">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-dark dark:text-white mb-8">Legal Notice</h1>

        <div class="prose prose-lg dark:prose-invert max-w-none">
          <p class="mb-6">Last updated: April 6, 2026</p>

          <h2>Company Information</h2>
          <p>Above and Beyond Home Solutions, LLC<br>
          Southwest Florida<br>
          Email: info@aboveandbeyondhomesolutions.com<br>
          Phone: (239) 555-0123</p>

          <h2>Professional Standards</h2>
          <p>Our inspectors are licensed and certified professionals. We adhere to InterNACHI standards and local regulations.</p>

          <h2>Disclaimer</h2>
          <p>The information provided on this website is for general informational purposes only. While we strive for accuracy, we make no representations or warranties of any kind.</p>

          <h2>Copyright Notice</h2>
          <p>All content on this website is the property of Above and Beyond Home Solutions, LLC and is protected by copyright laws.</p>

          <h2>Contact Us</h2>
          <p>For legal inquiries, please contact our office directly.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>