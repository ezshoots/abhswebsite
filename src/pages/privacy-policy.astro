---
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  description="Privacy Policy for Above and Beyond Home Solutions. Learn how we collect, use, and protect your personal information."
  title="Privacy Policy | Above and Beyond Home Solutions"
>
  <Breadcrumb>
    <Fragment slot="title">Privacy Policy</Fragment>
  </Breadcrumb>

  <section class="bg-white dark:bg-dark-2 py-20 lg:py-[110px]">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-dark dark:text-white mb-8">Privacy Policy</h1>

        <div class="prose prose-lg dark:prose-invert max-w-none">
          <p class="mb-6">Last updated: April 6, 2026</p>

          <h2>Information We Collect</h2>
          <p>We collect information you provide directly to us, such as when you contact us, schedule an inspection, or sign up for our services. This may include your name, email address, phone number, and property information.</p>

          <h2>How We Use Your Information</h2>
          <p>We use the information we collect to provide, maintain, and improve our home inspection services, communicate with you, and comply with legal obligations.</p>

          <h2>Information Sharing</h2>
          <p>We do not sell, trade, or otherwise transfer your personal information to third parties without your consent, except as described in this policy.</p>

          <h2>Data Security</h2>
          <p>We implement appropriate security measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction.</p>

          <h2>Contact Us</h2>
          <p>If you have any questions about this Privacy Policy, please contact us at info@abovebeyondhomesolutions.com.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>