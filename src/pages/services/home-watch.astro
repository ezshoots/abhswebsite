---
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import CTAsection from '../../components/CTAsection.astro';
import Layout from '../../layouts/Layout.astro';

const whatWeCheck = [
  {
    title: 'Water Damage & Leaks',
    description:
      'We check under sinks, around appliances, water heaters, and along ceilings and walls for signs of active leaks or water intrusion. In Florida\'s rain-heavy climate, even a small leak can escalate quickly while a home is unoccupied.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>`,
  },
  {
    title: 'HVAC Operation',
    description:
      'We verify that your air conditioning system is running and maintaining the target temperature. An HVAC failure in a sealed, unoccupied Florida home can cause mold to develop within days, especially during summer months in Fort Myers, Cape Coral, and Naples.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m1.636-6.364l.707.707M12 21v-1m-6.364-1.636l.707-.707M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  },
  {
    title: 'Mold & Moisture',
    description:
      'We look for early signs of mold growth in bathrooms, under sinks, in closets, and any areas prone to moisture accumulation. Catching mold at its earliest stage prevents a minor issue from becoming a costly remediation project.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>`,
  },
  {
    title: 'Pest Activity',
    description:
      'Florida is home to termites, ants, rodents, and other pests that exploit vacant properties. We look for evidence of activity including droppings, tunnels, damage, or entry points so problems can be addressed before they spread.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
  },
  {
    title: 'Security & Storm Readiness',
    description:
      'We check that doors, windows, and entry points are properly secured. During hurricane season we can confirm storm shutters are deployed or that windows are locked, and alert you to any breaches or vulnerabilities before a storm arrives.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
  {
    title: 'Exterior & Landscape',
    description:
      'We walk the exterior to check for storm damage, debris accumulation, irrigation system issues, and any visible damage to the roof, gutters, or structure. We also note overgrown vegetation that may be affecting the home\'s drainage or pest exposure.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
];

const plans = [
  {
    name: 'Weekly',
    best: 'Best for extended absences',
    description: 'Seven-day visit intervals. Ideal for summer snowbirds away May through October, or any homeowner away for several months.',
    features: ['Weekly property walkthrough', 'Interior & exterior check', 'Photo report after every visit', 'Email summary with findings', 'Emergency contact notifications'],
  },
  {
    name: 'Bi-Weekly',
    best: 'Most popular plan',
    description: 'Two-week visit intervals. A balanced option for homeowners who travel frequently throughout the year.',
    features: ['Every-two-week property walkthrough', 'Interior & exterior check', 'Photo report after every visit', 'Email summary with findings', 'Emergency contact notifications'],
  },
  {
    name: 'Monthly',
    best: 'Short trips & occasional travel',
    description: 'Monthly visit intervals. Best suited for homeowners who are away for shorter periods and want a baseline level of oversight.',
    features: ['Monthly property walkthrough', 'Interior & exterior check', 'Photo report after every visit', 'Email summary with findings', 'Emergency contact notifications'],
  },
];
---

<Layout
  title="Home Watch Services | Above and Beyond Home Solutions"
  description="Professional home watch services in Fort Myers, Cape Coral, Naples, Bonita Springs, Estero, Sarasota, and Southwest Florida. Scheduled property checks with photo reports for snowbirds and seasonal residents."
>
  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Home Watch Services",
    "serviceType": "Home Watch",
    "description": "Professional home watch services for snowbirds and seasonal residents in Southwest Florida. Scheduled property checks with photo reports covering water damage, HVAC operation, mold, and exterior conditions.",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Above and Beyond Home Solutions, LLC",
      "url": "https://www.abovebeyondhomesolutions.com"
    },
    "areaServed": ["Fort Myers, FL","Cape Coral, FL","Lehigh Acres, FL","Naples, FL","North Port, FL","Sarasota, FL","Port Charlotte, FL","Punta Gorda, FL","Bonita Springs, FL","Estero, FL","Marco Island, FL"],
    "url": "https://www.abovebeyondhomesolutions.com/services/home-watch"
  }
  </script>
  <Breadcrumb pageTitle="Home Watch Services">
    <Fragment slot="title">Home Watch Services</Fragment>
  </Breadcrumb>

  <!-- ====== Overview Section Start -->
  <section class="py-20 dark:bg-dark lg:py-[120px]">
    <div class="container">
      <div class="-mx-4 flex flex-wrap items-center">

        <!-- Text column -->
        <div class="w-full px-4 lg:w-1/2">
          <div class="mb-12 lg:mb-0 lg:pr-10">
            <span class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
              Property Monitoring
            </span>
            <h2 class="mb-5 mt-3 text-3xl font-bold text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
              Peace of Mind While You're Away
            </h2>
            <p class="mb-5 text-base leading-relaxed text-body-color dark:text-dark-6">
              Southwest Florida is one of the most popular seasonal destinations in the country. Tens of thousands of homeowners in Lee County, Collier County, Charlotte County, and Sarasota County spend part of the year away from their Florida properties. An empty home is a vulnerable home.
            </p>
            <p class="mb-8 text-base leading-relaxed text-body-color dark:text-dark-6">
              Our home watch service provides scheduled, documented property checks by a licensed inspector who knows what to look for. From HVAC failures to water leaks to storm damage, we catch problems early, before they turn into costly repairs, and send you a photo report after every visit so you always know what's happening at your home.
            </p>
            <a
              href="/schedule"
              class="inline-flex items-center justify-center rounded-md bg-primary px-7 py-3 text-base font-medium text-white shadow-sm transition-all duration-300 ease-in-out hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
            >
              Set Up Home Watch
            </a>
          </div>
        </div>

        <!-- Image / stat column -->
        <div class="w-full px-4 lg:w-1/2">
          <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary/10 to-primary/5 p-1 ring-1 ring-primary/20 dark:from-primary/20 dark:to-primary/10">
            <img
              src="/assets/blog/blog-details-01.jpg"
              alt="Home watch property inspection"
              class="w-full rounded-xl object-cover"
              style="aspect-ratio: 16/10;"
            />
          </div>

          <!-- Stat strip -->
          <div class="mt-6 grid grid-cols-3 divide-x divide-stroke dark:divide-dark-3 rounded-xl border border-stroke dark:border-dark-3 bg-white dark:bg-dark-2">
            <div class="px-5 py-4 text-center">
              <p class="text-2xl font-bold text-dark dark:text-white">Photo</p>
              <p class="mt-1 text-xs text-body-color dark:text-dark-6">Reports Every Visit</p>
            </div>
            <div class="px-5 py-4 text-center">
              <p class="text-2xl font-bold text-dark dark:text-white">Weekly</p>
              <p class="mt-1 text-xs text-body-color dark:text-dark-6">Visits Available</p>
            </div>
            <div class="px-5 py-4 text-center">
              <p class="text-2xl font-bold text-dark dark:text-white">Licensed</p>
              <p class="mt-1 text-xs text-body-color dark:text-dark-6">Inspector</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- ====== Overview Section End -->

  <!-- ====== What We Check Section Start -->
  <section class="bg-gray-1 py-20 dark:bg-dark-2 lg:py-[120px]">
    <div class="container">
      <div class="mx-auto mb-12 max-w-2xl text-center lg:mb-[70px]">
        <span class="mb-3 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
          Every Visit
        </span>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
          What We Check on Every Property Visit
        </h2>
        <p class="mt-4 text-base leading-relaxed text-body-color dark:text-dark-6">
          Our licensed inspectors conduct a thorough walkthrough inside and outside the home on each visit. Nothing is skimmed. Every check is documented with photos.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
        {whatWeCheck.map((item) => (
          <div class="group rounded-2xl border border-black/5 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:ring-1 hover:ring-primary/20 dark:border-white/10 dark:bg-dark">
            <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 ring-1 ring-primary/20 transition-transform duration-300 group-hover:scale-[1.05]">
              <svg
                class="h-6 w-6 text-primary"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <Fragment set:html={item.icon} />
              </svg>
            </div>
            <h3 class="mb-3 text-lg font-semibold text-dark dark:text-white">{item.title}</h3>
            <p class="text-sm leading-relaxed text-body-color dark:text-dark-6">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <!-- ====== What We Check Section End -->

  <!-- ====== Plans Section Start -->
  <section class="py-20 dark:bg-dark lg:py-[120px]">
    <div class="container">
      <div class="mx-auto mb-12 max-w-2xl text-center lg:mb-[70px]">
        <span class="mb-3 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
          Visit Schedules
        </span>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
          Choose Your Visit Frequency
        </h2>
        <p class="mt-4 text-base leading-relaxed text-body-color dark:text-dark-6">
          We offer flexible scheduling to match how long and how often you're away. All plans include photo documentation and email reports after each visit.
        </p>
      </div>

      <div class="-mx-4 flex flex-wrap justify-center gap-y-8">
        {plans.map((plan, i) => (
          <div class="w-full px-4 md:w-1/2 lg:w-1/3">
            <div class={`h-full rounded-2xl border p-8 shadow-sm ${i === 1 ? 'border-primary/20 bg-white ring-1 ring-primary/20 shadow-md dark:bg-dark' : 'border-black/5 bg-white dark:border-white/10 dark:bg-dark'}`}>
              {i === 1 && (
                <span class="mb-4 inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
                  Most Popular
                </span>
              )}
              <h3 class="mb-1 text-2xl font-bold text-dark dark:text-white">{plan.name}</h3>
              <p class="mb-4 text-sm font-medium text-primary">{plan.best}</p>
              <p class="mb-6 text-sm leading-relaxed text-body-color dark:text-dark-6">{plan.description}</p>
              <ul class="mb-8 space-y-3">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-primary/10">
                      <svg class="h-3 w-3 text-primary" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                    </span>
                    <span class="text-sm text-body-color dark:text-dark-6">{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href="/schedule"
                class={`block w-full rounded-md px-6 py-3 text-center text-sm font-semibold transition-all duration-300 hover:-translate-y-[1px] ${i === 1 ? 'bg-primary text-white shadow-sm hover:bg-blue-dark hover:shadow-md' : 'border border-primary/30 text-primary hover:bg-primary/5'}`}
              >
                Get Started
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <!-- ====== Plans Section End -->

  <!-- ====== Who It's For Section Start -->
  <section class="bg-gray-1 py-20 dark:bg-dark-2 lg:py-[120px]">
    <div class="container">
      <div class="-mx-4 flex flex-wrap items-center">

        <div class="w-full px-4 lg:w-1/2">
          <div class="relative overflow-hidden rounded-2xl">
            <img
              src="/assets/blog/blog-01.webp"
              alt="Southwest Florida seasonal home"
              class="w-full rounded-2xl object-cover"
              style="aspect-ratio: 4/3;"
            />
            <div class="absolute bottom-4 left-4 flex items-center gap-3 rounded-xl bg-white/90 px-4 py-3 shadow-md backdrop-blur dark:bg-dark/90">
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-primary/10">
                <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <div>
                <p class="text-sm font-semibold text-dark dark:text-white">Licensed Inspector On Every Visit</p>
                <p class="text-xs text-body-color dark:text-dark-6">Not a property manager. A licensed inspector.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full px-4 lg:w-1/2">
          <div class="mt-10 lg:mt-0 lg:pl-12">
            <span class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary">
              Who It's For
            </span>
            <h2 class="mb-5 mt-3 text-3xl font-bold text-dark dark:text-white sm:text-4xl md:text-[42px] md:leading-[1.15]">
              Built for Southwest Florida's Seasonal Residents
            </h2>
            <p class="mb-5 text-base leading-relaxed text-body-color dark:text-dark-6">
              If you spend summers up north and winters in Naples, Bonita Springs, Fort Myers Beach, Sanibel, or Marco Island, or if you travel frequently throughout the year, our home watch service keeps your property protected while you're away.
            </p>
            <p class="mb-8 text-base leading-relaxed text-body-color dark:text-dark-6">
              What sets us apart from typical home watch companies is that our visits are conducted by a licensed home inspector. We don't just walk through and look for obvious problems. We know what to look for, and we document it all with the same thoroughness we bring to every inspection.
            </p>

            <ul class="mb-8 space-y-3">
              {[
                'Snowbirds and seasonal residents heading north for summer',
                'Owners of vacation or investment properties in SW Florida',
                'Homeowners traveling frequently for work or family',
                'Anyone who wants documented peace of mind between visits',
              ].map((point) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-primary/10">
                    <svg class="h-3 w-3 text-primary" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                  </span>
                  <span class="text-base text-body-color dark:text-dark-6">{point}</span>
                </li>
              ))}
            </ul>

            <a
              href="/schedule"
              class="inline-flex items-center justify-center rounded-md bg-primary px-7 py-3 text-base font-medium text-white shadow-sm transition-all duration-300 ease-in-out hover:-translate-y-[1px] hover:bg-blue-dark hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
            >
              Start Home Watch Service
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- ====== Who It's For Section End -->

  <CTAsection />
</Layout>
