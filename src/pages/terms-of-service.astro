---
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  description="Terms of Service for Above and Beyond Home Solutions. Read our terms and conditions for using our home inspection services."
  title="Terms of Service | Above and Beyond Home Solutions"
>
  <Breadcrumb>
    <Fragment slot="title">Terms of Service</Fragment>
  </Breadcrumb>

  <section class="bg-white dark:bg-dark-2 py-20 lg:py-[110px]">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-dark dark:text-white mb-8">Terms of Service</h1>

        <div class="prose prose-lg dark:prose-invert max-w-none">
          <p class="mb-6">Last updated: April 6, 2026</p>

          <h2>Acceptance of Terms</h2>
          <p>By accessing and using Above and Beyond Home Solutions' services, you accept and agree to be bound by the terms and provision of this agreement.</p>

          <h2>Services</h2>
          <p>We provide professional home inspection services. Our inspections are conducted in accordance with industry standards and local regulations.</p>

          <h2>Limitation of Liability</h2>
          <p>Our inspections are visual and non-invasive. We cannot guarantee the discovery of all defects or issues. Our liability is limited to the cost of the inspection.</p>

          <h2>Payment Terms</h2>
          <p>Payment is due upon completion of services unless otherwise agreed. We accept various payment methods as outlined at the time of service.</p>

          <h2>Contact Information</h2>
          <p>For questions about these Terms of Service, please contact us at info@aboveandbeyondhomesolutions.com.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>